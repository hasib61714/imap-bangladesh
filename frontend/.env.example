# ─────────────────────────────────────────
#  IMAP Bangladesh – Frontend Environment
#  Copy to .env.production and set your values
# ─────────────────────────────────────────

# Backend API URL (no trailing slash)
VITE_API_URL=https://api.yourdomain.com/api

# Google OAuth Client ID — https://console.cloud.google.com
# Required for real Google One-Tap login
# Leave blank to use dev-mode mock (no real Google popup)
VITE_GOOGLE_CLIENT_ID=

# App Name / branding override (optional)
VITE_APP_NAME=IMAP
VITE_APP_URL=https://yourdomain.com
