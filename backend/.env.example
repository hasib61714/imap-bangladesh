# ─────────────────────────────────────────
#  IMAP Bangladesh – Backend Environment
#  Copy this file to .env and fill values
# ─────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=production

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_strong_db_password_here
DB_NAME=imap_db

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS) — no trailing slash
FRONTEND_URL=https://yourdomain.com

# AI Keys (optional — leave blank to use keyword fallback)
GEMINI_API_KEY=
OPENAI_API_KEY=
