# ─────────────────────────────────────────
#  IMAP Bangladesh – Backend Environment
#  Copy this file to .env and fill values
# ─────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=production

# MySQL / TiDB Cloud
DB_HOST=gateway01.ap-northeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=your_tidb_username.root
DB_PASSWORD=your_tidb_password
DB_NAME=imap_db
DB_SSL=true

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS) — no trailing slash
FRONTEND_URL=https://yourdomain.com

# AI Keys (optional — leave blank to use keyword fallback)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Google OAuth — get from https://console.cloud.google.com → APIs & Services → Credentials
# Required for real Google login (leave blank to use dev-mode mock)
GOOGLE_CLIENT_ID=

# SSLCommerz Payment Gateway — https://developer.sslcommerz.com
# Leave blank to run in mock/dev mode
SSL_STORE_ID=
SSL_STORE_PASSWORD=
SSL_IS_SANDBOX=true

# SMS (Twilio / BD SMS gateway)
# SMS_PROVIDER=mock   ← uses mock by default, change to 'twilio' or 'bdsms'
SMS_PROVIDER=mock
SMS_FROM=+880XXXXXXXXXX
# Twilio:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# BD SMS Gateway (e.g. Shajogoj / BulkSMS):
BD_SMS_API_KEY=
BD_SMS_SENDER_ID=

# Web Push Notifications (VAPID keys)
# Generate: node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(k);"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:admin@imap.bd

# Cloud Storage — Cloudflare R2 (recommended, S3-compatible)
# Leave all blank to use base64 dev fallback
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=imap-uploads
R2_PUBLIC_URL=https://pub-XXXX.r2.dev

# AWS S3 (alternative to R2)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=

# Demo seed endpoint secret
# GET /api/admin/seed-demo?secret=<this value>
# Leave blank to allow public bootstrap when DB is empty
SEED_SECRET=
