{
  "name": "imap-backend",
  "version": "1.0.0",
  "description": "IMAP Bangladesh REST API - Node.js + Express + MySQL",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test",
